\@writefile{lot}{\contentsline {table}{\numberline {4.2}{\ignorespaces Scaler comparison for clustering}}{72}{table.caption.92}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.6}Clustering Experiments}{73}{subsection.4.2.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.3}{\ignorespaces Clustering algorithms evaluated}}{73}{table.caption.93}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.4}{\ignorespaces Four complementary clustering metrics}}{73}{table.caption.94}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.13}{\ignorespaces Elbow curve --- the inertia curve bends most sharply between $K=3$ and $K=5$, after which adding more clusters yields diminishing reductions in within-cluster variance.}}{74}{figure.caption.95}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.14}{\ignorespaces Silhouette vs.\ K --- the silhouette score peaks at $K=5$, indicating that five clusters achieve the optimal balance between intra-cluster compactness and inter-cluster separation.}}{75}{figure.caption.96}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{K-Means From Scratch --- Core Implementation}{75}{figure.caption.96}\protected@file@percent }
\@writefile{lol}{\contentsline {lstlisting}{\numberline {4.1}{\ignorespaces K-Means: k-means++ init + assignment-update loop}}{75}{lstlisting.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.7}Model Selection}{76}{subsection.4.2.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.15}{\ignorespaces The most important clustering result: $K=5$ clusters on Income vs.\ Spending Score with centroid markers --- 5 distinct, well-separated customer segments with no significant overlap between adjacent clusters.}}{77}{figure.caption.97}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Centroid Trajectory Visualization}{77}{figure.caption.97}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.16}{\ignorespaces Centroid trajectory: iteration-by-iteration movement from k-means++ initialization to convergence. Smooth paths within 8--12 iterations confirm stable optimization with no oscillation or divergence.}}{78}{figure.caption.98}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.8}Cluster Visualization}{78}{subsection.4.2.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.17}{\ignorespaces PCA 2D projection: first two principal components with cluster assignments. The separation visible in PC1--PC2 space confirms that the cluster structure persists even after linear dimensionality reduction, with PC1 capturing primarily income variation and PC2 capturing spending variation.}}{79}{figure.caption.99}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.18}{\ignorespaces Age vs.\ Spending Score --- cluster membership is projected onto the age-spending plane. The substantial overlap between clusters confirms that age is not a strong cluster discriminator, supporting the decision to exclude it from the final model.}}{79}{figure.caption.100}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.19}{\ignorespaces Age vs.\ Annual Income --- cluster colors are preserved from the income-spending model. The lack of clean separation along the age axis reinforces that age contributes minimal additional information.}}{80}{figure.caption.101}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.20}{\ignorespaces GMM on Income vs.\ Spending --- soft cluster memberships shown via color blending where points have non-trivial probability of belonging to multiple components.}}{81}{figure.caption.102}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.21}{\ignorespaces GMM covariance contours at $1\sigma $, $2\sigma $, and $3\sigma $ --- ellipses are roughly circular, confirming that cluster covariances are near-isotropic and supporting K-Means's spherical assumption.}}{82}{figure.caption.103}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.9}Segment Profiling}{82}{subsection.4.2.9}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.5}{\ignorespaces Five segments with recommended business actions}}{82}{table.caption.104}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.10}Deployment Check}{83}{subsection.4.2.10}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.3}Results and Analysis}{83}{section.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.22}{\ignorespaces GMM with 4 components and covariance contours on Income vs.\ Spending scatter. Ellipses at $1\sigma $, $2\sigma $, and $3\sigma $ reveal cluster shape and orientation --- most components are near-circular, confirming that the spherical K-Means assumption holds well for these data.}}{84}{figure.caption.105}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.23}{\ignorespaces Cluster centers in original feature scale --- inverse-transformed from StandardScaler for business-interpretable segment profiles. The five centroids map cleanly onto the five behavioral archetypes identified in the segment profiling table.}}{84}{figure.caption.106}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.24}{\ignorespaces Agglomerative clustering dendrogram --- hierarchical view of cluster merging distances on a sample subset. The dendrogram confirms that five is a natural cut point: the merge distance increases sharply when reducing from 5 to 4 clusters, indicating that the five-cluster solution captures genuine structure rather than an arbitrary partition.}}{85}{figure.caption.107}\protected@file@percent }
