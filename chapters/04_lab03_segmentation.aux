\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Income vs.\ Spending Score --- five distinct point clouds are visible on the original scale, separated along both income and spending axes. This visual structure predicts strong clustering performance.}}{66}{figure.caption.83}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Pairwise scatter matrix --- the income-spending panel (bottom-left / top-right quadrant) exhibits the clearest cluster separation. Age-forming panels show diffuse overlap, suggesting age is a weaker discriminative feature.}}{67}{figure.caption.84}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces Correlation heatmap --- no $|r| > 0.700$ redundancies, confirming all features contribute independent information. The weak correlations ($|r| < 0.300$ across all feature pairs) justify including all numeric features in the initial clustering search while keeping the feature set compact.}}{68}{figure.caption.85}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces Age vs.\ Spending Score --- points are broadly scattered without clear cluster boundaries, indicating that age alone cannot segment customers by spending behavior.}}{69}{figure.caption.86}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Age vs.\ Annual Income --- no strong linear or monotonic relationship is visible; older customers are not systematically wealthier in this dataset.}}{70}{figure.caption.87}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.9}{\ignorespaces Age distribution --- roughly uniform between 20 and 70, with a slight concentration in the 30--40 band.}}{70}{figure.caption.88}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.10}{\ignorespaces Annual income distribution --- right-skewed with a median near \$60k and a long tail extending to \$137k. This skew motivates RobustScaler for distance-based clustering.}}{71}{figure.caption.89}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.11}{\ignorespaces Spending score distribution --- bimodal with peaks near 40--45 and 70--80, supporting the hypothesis of two broad behavioral groups (low-spending and high-spending) that further subdivide by income.}}{71}{figure.caption.90}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.12}{\ignorespaces Gender distribution --- note any imbalance that may affect segment interpretation.}}{72}{figure.caption.91}\protected@file@percent }
