\@writefile{lof}{\contentsline {figure}{\numberline {3.32}{\ignorespaces RMSLE comparison across models. HGB (log features) achieves the lowest individual RMSLE (0.464); the ensemble achieves 0.483 with strong secondary metrics.}}{49}{figure.caption.52}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.33}{\ignorespaces RMSLE improvement deltas: HGB, MLP, and Ridge with log features all improve on the baselines; HGB log features provides the largest improvement over the best RMSLE baseline (Rolling\_Mean\_56\_Shift16 at 0.546).}}{49}{figure.caption.53}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.34}{\ignorespaces Log-scale loss curves — revealing fine-grained convergence behavior, especially for MLP where early epochs show rapid descent followed by gradual refinement.}}{50}{figure.caption.54}\protected@file@percent }
