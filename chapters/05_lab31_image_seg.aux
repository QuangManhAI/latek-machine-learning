\@writefile{lot}{\contentsline {table}{\numberline {5.1}{\ignorespaces Expected behavior per K value}}{91}{table.caption.114}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Metrics Collected Per Run}{91}{table.caption.114}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Elbow Method}{91}{table.caption.114}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.7}{\ignorespaces Elbow curve for the primary image: inertia vs. K shows a clear bend at K=5. The steep drop from K=2 to K=5 (total 87.027\% reduction) contrasts with the shallow decline from K=5 to K=8 (39.813\% across three additional clusters).}}{92}{figure.caption.115}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.8}{\ignorespaces Elbow curve for \texttt  {picture\_2.jpg}: with only 8{,}231 unique colors, the bend appears earlier at K=3.}}{92}{figure.caption.116}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.9}{\ignorespaces Elbow curve for \texttt  {picture\_3.jpg}: bend at K=5, consistent with its 12{,}631 unique colors requiring more centroids for adequate representation.}}{93}{figure.caption.117}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Silhouette Analysis}{93}{figure.caption.117}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.10}{\ignorespaces Silhouette analysis for the primary image at K=5. The dashed red line marks the average silhouette of 0.518. Uniformly thick bars across all five clusters confirm well-separated, compact color groups. No cluster shows bars near zero, indicating minimal overlap.}}{94}{figure.caption.118}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.11}{\ignorespaces Silhouette analysis for \texttt  {picture\_2.jpg} at K=3 (average 0.748). The three clusters are very well-separated, reflecting the image's simpler color structure with only 8{,}231 unique colors.}}{95}{figure.caption.119}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.12}{\ignorespaces Silhouette analysis for \texttt  {picture\_3.jpg} at K=5 (average 0.835). The exceptionally high silhouette indicates five nearly non-overlapping color populations — the strongest cluster structure across all images.}}{96}{figure.caption.120}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2.6}Image Reconstruction}{96}{subsection.5.2.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.13}{\ignorespaces Original vs. K=5 segmented comparison for the primary image. The right panel shows the reconstructed image using only 5 colors — edges remain sharp, major color regions (sky, vegetation, water) are preserved, and fine texture is maintained despite the 9{,}423.800:1 compression ratio.}}{97}{figure.caption.121}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.14}{\ignorespaces Original vs. K=3 segmented comparison for \texttt  {picture\_2.jpg}. With only 8{,}231 unique colors originally, three centroids achieve a compression ratio of 2{,}743.667:1 while preserving the essential scene structure.}}{97}{figure.caption.122}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.15}{\ignorespaces Original vs. K=5 segmented comparison for \texttt  {picture\_3.jpg}. Compression ratio of 2{,}526.200:1 from 12{,}631 unique colors.}}{98}{figure.caption.123}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2.7}Visualize Results}{98}{subsection.5.2.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.16}{\ignorespaces K-comparison grid for the primary image: original (left) alongside K=2, 3, 5, 8 segmented variants. The progression from harsh two-tone posterization at K=2 to near-photographic fidelity at K=8 is clearly visible. K=5 is the first value where textures and edges appear natural.}}{99}{figure.caption.124}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.17}{\ignorespaces Convergence plot for the primary image: inertia decreases monotonically for all K. K=8 requires the most iterations (49) due to the increased complexity of coordinating eight centroids, but the descent remains smooth without oscillation.}}{99}{figure.caption.125}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.18}{\ignorespaces Centroid color palette for the primary image at K=5. The five swatches are perceptually distinct, confirming that the algorithm has identified meaningful, separable color regions rather than degenerate or overlapping clusters.}}{100}{figure.caption.126}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.19}{\ignorespaces K-comparison grid for \texttt  {picture\_2.jpg} at its optimal K=3.}}{100}{figure.caption.127}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.20}{\ignorespaces K-comparison grid for \texttt  {picture\_3.jpg} at its optimal K=5.}}{101}{figure.caption.128}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.21}{\ignorespaces Convergence plot for \texttt  {picture\_2.jpg}: fast convergence (10 iterations at K=3) due to limited color diversity.}}{101}{figure.caption.129}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.22}{\ignorespaces Convergence plot for \texttt  {picture\_3.jpg}: 11 iterations at K=5, reflecting well-separated initial clusters.}}{102}{figure.caption.130}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.23}{\ignorespaces Centroid color palette for \texttt  {picture\_2.jpg} at K=3.}}{102}{figure.caption.131}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.24}{\ignorespaces Centroid color palette for \texttt  {picture\_3.jpg} at K=5.}}{102}{figure.caption.132}\protected@file@percent }
